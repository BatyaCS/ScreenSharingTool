{
  "name": "p2p-screen-sharing-tool",
  "version": "0.1.0",
  "dependencies": [
    "stb",
    {
      "name": "opencv4",
      "default-features": false,
      "features": [
        "png", 
        "jpeg", 
        "ffmpeg", 
        "highgui", 
        "opengl",
        "win32ui"
      ]
    },
    {
      "name": "ffmpeg",
      "features": ["x264"] 
    },
    "glfw3",
    {
      "name": "imgui",
      "features": ["glfw-binding", "opengl3-binding"]
    },
    {
      "name": "libsrt"
    }
  ]
}